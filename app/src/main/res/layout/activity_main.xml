<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <!-- Logo circle -->
            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_logo_circle"
                android:layout_gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="MW"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MW AI"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI-асистент поверх будь-якого додатку"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Статус"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○ Неактивно"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- API Key card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anthropic API Ключ"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Отримай на console.anthropic.com"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="sk-ant-..."
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:textSize="13sp"
                android:inputType="textPassword"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_save_key"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Зберегти ключ"
                android:background="@drawable/bg_btn_secondary"
                android:textColor="@color/accent_purple"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Instructions card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Як користуватись"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="① Введи API ключ і збережи\n② Натисни «Запустити MW AI»\n③ Дозволь відображення поверх додатків\n④ Кнопка MW AI з'явиться на екрані\n\n🔵 1 клік — аналіз екрану\n🔵 2 кліки — сховати кнопку\n🔵 2 кліки на місці — показати знову\n\n✕ Закрити панель — 1 клік\n✕✕ Подвійний клік ✕ — сховати все"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

        <!-- Launch button -->
        <Button
            android:id="@+id/btn_launch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Запустити MW AI"
            android:background="@drawable/bg_btn_primary"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Зупинити"
            android:background="@drawable/bg_btn_danger"
            android:textColor="@color/accent_red"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
