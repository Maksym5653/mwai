<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient android:startColor="#5B21B6" android:endColor="#4C1D95" android:angle="135"/>
            <stroke android:width="2dp" android:color="#A78BFA"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient android:startColor="#7C3AED" android:endColor="#1E1B4B" android:angle="135"/>
            <stroke android:width="2dp" android:color="#7C3AED"/>
        </shape>
    </item>
</selector>
